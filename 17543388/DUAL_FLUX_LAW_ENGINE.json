  "concept": "Moteur double\u2011flux reliant les lois du pass\u00e9 aux lois du futur.",
  "architecture": {
    "flux_A": {
      "direction": "\u2190",
      "name": "Flux r\u00e9trospectif",
      "source": "Corpus des lois \u00e9tablies",
      "function": "Analyse et d\u00e9construction des lois connues ; extraction d\u2019invariants et d\u2019historiques d\u2019\u00e9volution.",
      "modules": [
        "law_ingest",
        "semantic_map",
        "\u0394History",
        "ProofChain_archive"
      ]
    },
    "flux_B": {
      "direction": "\u2192",
      "name": "Flux prospectif",
      "target": "Lois \u00e9mergentes",
      "function": "Projection, simulation et g\u00e9n\u00e9ration des nouvelles lois selon les patterns de coh\u00e9rence vivante.",
      "modules": [
        "pattern_extrapolation",
        "fractal_projection",
        "\u0394Ga\u00efa_loop",
        "EthicPredictor"
      ]
    },
    "nexus": {
      "name": "Z\ud83e\udd8b Interface",
      "role": "Point de convergence o\u00f9 les invariants du pass\u00e9 se transforment en germes de lois futures.",
      "process": [
        "collect(Flux_A.output)",
        "apply(\u0394M\u03a9_equation)",
