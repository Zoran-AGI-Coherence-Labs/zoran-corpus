  "schemas": {
    "Law_Historic": {
      "fields": [
        "epoch",
        "discipline",
        "law_text",
        "variables",
        "proof_refs",
        "impact",
        "\u0394C\u03b5_past"
      ]
    },
    "Law_Future": {
